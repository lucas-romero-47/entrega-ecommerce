<div id="cart-container" data-id="{{cart._id}}" class="container my-5">
  <div class="card shadow-lg border-0 rounded-4">
    <div class="card-header bg-primary text-white py-4 px-4 rounded-top-4">
      <h2 class="mb-0 fw-bold">Detalles de tu Carrito</h2>
      <p class="mb-0 opacity-75">ID: {{cart._id}}</p>
    </div>

    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4 py-3">Producto</th>
              <th class="py-3">Categoría</th>
              <th class="py-3 text-center">Cantidad</th>
              <th class="py-3 text-end">Precio Unitario</th>
              <th class="py-3 text-center pe-4">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each cart.products}}
              <tr>
                <td class="ps-4 fw-semibold">{{this.product.title}}</td>
                <td><span
                    class="badge bg-secondary opacity-75"
                  >{{this.product.category}}</span></td>
                <td class="text-center">
                  <span
                    class="badge bg-info text-dark px-3 py-2"
                  >{{this.quantity}}</span>
                </td>
                <td
                  class="text-end fw-bold text-success"
                >${{this.product.price}}</td>
                <td class="text-center pe-4">
                  <button
                    class="btn btn-outline-danger btn-sm rounded-pill px-3"
                    onclick="deleteProduct('{{this.product._id}}')"
                  >
                    Eliminar
                  </button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    <div
      class="card-footer bg-white py-4 px-4 d-flex justify-content-between rounded-bottom-4 border-top-0"
    >
      <a href="/" class="btn btn-outline-primary rounded-pill fw-bold px-4">
        Seguir comprando
      </a>
      <button
        class="btn btn-danger rounded-pill fw-bold px-4"
        onclick="clearCart()"
      >
        Vaciar Carrito
      </button>
    </div>
  </div>
</div>

<script>
  function deleteProduct(pid) { var container =
  document.getElementById('cart-container'); var cid =
  container.getAttribute('data-id').replace(/\s/g, ''); var cleanPid =
  pid.replace(/\s/g, ''); fetch("/api/carts/" + cid + "/products/" + cleanPid, {
  method: "DELETE" }) .then(function(res) { if (res.ok) {
  window.location.reload(); } else { console.log("Error status: " + res.status);
  } }) .catch(function(err) { console.log(err); }); } function clearCart() { var
  container = document.getElementById('cart-container'); var cid =
  container.getAttribute('data-id').replace(/\s/g, ''); fetch("/api/carts/" +
  cid, { method: "DELETE" }) .then(function(res) { if (res.ok) {
  window.location.reload(); } }) .catch(function(err) { console.log(err); }); }
</script>